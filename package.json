{
    "name": "olimp-bot-payment",
    "version": "1.0.0",
    "description": "Telegram subscription payment bot — sells access to a private channel",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "dev": "ts-node-dev --respawn src/index.ts",
        "build": "tsc --project tsconfig.json && cp -R src/generated dist/generated && mkdir -p dist/locales && cp src/locales/*.json dist/locales/",
        "start": "node dist/index.js",
        "db:generate": "prisma generate",
        "db:migrate:dev": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "keywords": [
        "telegram",
        "bot",
        "payment",
        "subscription"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "@types/express": "^5.0.6",
        "axios": "^1.16.1",
        "bullmq": "^5.71.1",
        "express": "^5.2.1",
        "ioredis": "5.10.1",
        "pg": "^8.20.0",
        "telegraf": "^4.16.3",
        "telegraf-ratelimit": "^2.0.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^6.0.2",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/pg": "^8.20.0",
        "@vitest/coverage-v8": "^4.1.1",
        "dotenv": "^17.4.2",
        "prettier": "^3.8.1",
        "prettier-plugin-prisma": "^5.0.0",
        "prisma": "^7.5.0",
        "vitest": "^4.1.1"
    }
}
