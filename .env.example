# ---- Telegram ----
TELEGRAM_TOKEN=123456:ABC-your-bot-token
BOT_USERNAME=your_bot_username
# Comma-separated Telegram user IDs that get admin access
ADMIN_IDS=123456789

# ID закрытого (платного) канала с контентом — продукт подписки.
# Бот ДОЛЖЕН быть администратором этого канала (право приглашать по ссылке).
# Формат: -1001234567890
PAID_CHANNEL_ID=-1001234567890

# ---- Ручная оплата ----
# Username менеджера, которому пользователь шлёт скриншот оплаты
MANUAL_PAYMENT_MANAGER=@your_manager

# ---- Boosty / Tribute (внешние сервисы) ----
# Ссылка на страницу Boosty
BOOSTY_URL=https://boosty.to/YOUR_PAGE
# Ссылка на оплату через Tribute (если пусто — кнопка Tribute не показывается)
TRIBUTE_URL=

# ---- Crypto Pay (@CryptoBot) ----
CRYPTO_PAY_TOKEN=
CRYPTO_PAY_API_URL=https://pay.crypt.bot/api

# ---- Telegram Payments провайдеры (необязательно) ----
# Если токен пуст — соответствующий способ оплаты не показывается
PAYMENT_TOKEN_YOOKASSA=
YOOKASSA_TOKEN=
PAYMENT_TOKEN_PAYCOM_UZ=
PAYMENT_TOKEN_BEPAID_BY=
PAYMENT_TOKEN_ROBOKASSA_KZ=
PAYMENT_TOKEN_PORTMONE=
PAYMENT_TOKEN_UNLIMIT=

# ---- Инфраструктура ----
# ВАЖНО: этот бот рассчитан на совместную работу с основным ботом на одном
# сервере. Ресурсы разведены, чтобы не конфликтовать с основным ботом:
#   - основной бот:   PORT=3000, Redis .../0, база olimp_bot
#   - платёжный бот:  PORT=3001, Redis .../1, база olimp_bot_payment

# Отдельная база данных (у ботов разные схемы — общую БД использовать нельзя).
DATABASE_URL=postgresql://user:password@localhost:5432/olimp_bot_payment?schema=public

# Отдельный логический номер Redis-DB (у основного бота — /0), иначе сессии и
# очередь рассылки будут перетирать друг друга. В Docker Compose это не нужно —
# там у каждого бота свой контейнер Redis.
REDIS_URL=redis://localhost:6379/1

# Порт Express (webhook Crypto Pay). Основной бот занимает 3000 — берём 3001.
PORT=3001

# ---- Прочее ----
NODE_ENV=production
LOG_LEVEL=info
# Задержка между сообщениями рассылки, мс (200 => ~5 сообщений/сек)
BROADCAST_PACING_MS=200
